{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false
  },
  "include": [
    "src/index.ts",
    "src/core/**/*.ts",
    "src/plugins/**/*.ts"
  ],
  "exclude": [
    "src/main.ts",
    "src/transition-demo.ts",
    "src/playground/**/*.ts"
  ]
}